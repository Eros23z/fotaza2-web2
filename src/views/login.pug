extends layout

block content
  div.row
    div.col-md-6.col-lg-5.mx-auto
      div.card.shadow-sm.border-0.mt-4
        div.card-body.p-4
          h2.card-title.text-center.mb-4.fw-bold Iniciar Sesión
          
          if error
            div.alert.alert-danger.text-center.py-2.small #{error}

          form(action="/login" method="POST")
            div.mb-3
              label.form-label.small.fw-bold(for="username") Nombre de usuario:
              input.form-control(type="text" name="username" id="username" required)
            
            div.mb-3
              label.form-label.small.fw-bold(for="email") Correo Electrónico:
              input.form-control(type="email" name="email" id="email" required)
            
            div.mb-3
              label.form-label.small.fw-bold(for="password") Contraseña:
              input.form-control(type="password" name="password" id="password" required)

            button.btn.btn-primary.w-100.mt-3.fw-bold(type="submit") Entrar
          
          div.text-center.mt-4.small
            span ¿No tienes una cuenta? 
            a.text-decoration-none(href="/register") Regístrate aquí