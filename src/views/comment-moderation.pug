extends layout

block content
  div.row
    div.col-md-10.col-lg-8.mx-auto
      h2.fw-bold.mb-2
        i.bi.bi-chat-left-quote.me-2.text-primary
        | #{title || 'Moderación de Comentarios'}
      p.text-muted.small.mb-4 Aquí puedes ver y gestionar las denuncias realizadas sobre los comentarios en tus publicaciones.

      if reports && reports.length > 0
        each report in reports
          div.card.border-danger.mb-4.shadow-sm
            div.card-header.bg-danger-subtle.text-danger-emphasis.d-flex.justify-content-between.align-items-center.py-2
              span.fw-bold.small
                i.bi.bi-exclamation-octagon.me-1
                | Denuncia ##{report.id_denuncia} - Motivo: #{report.motivo}
              span.badge.bg-danger @#{report.username_denunciante}
            
            div.card-body
              p.small.fw-bold.mb-1 Comentario denunciado:
              p.bg-light.p-2.rounded.border.small.fst-italic.text-dark.mb-3
                | "#{report.texto_comentario}"
              
              p.small.fw-bold.mb-1 Explicación del denunciante:
              p.text-muted.small.mb-3= report.descripcion
              
              div.pt-2.border-top
                span.small.text-muted
                  strong Publicación original: 
                  a.fw-bold.text-decoration-none(href=`/posts-detail/${report.id_publicacion}` target="_blank") #{report.titulo_publicacion}

            div.card-footer.bg-light.d-flex.justify-content-end.gap-2.py-2
              form(action=`/profile/moderation/comments/${report.id_denuncia}/dismiss` method="POST" class="m-0")
                button.btn.btn-outline-secondary.btn-sm.fw-bold(type="submit")
                  i.bi.bi-check-lg.me-1
                  | Desestimar
              form(action=`/profile/moderation/comments/${report.id_denuncia}/delete` method="POST" class="m-0")
                button.btn.btn-danger.btn-sm.fw-bold(type="submit")
                  i.bi.bi-trash.me-1
                  | Borrar comentario
      else
        div.text-center.py-5.bg-white.rounded.shadow-sm.p-4
          i.bi.bi-shield-check.fs-1.text-muted
          p.text-muted.mt-2.small No tienes denuncias de comentarios pendientes en este momento.
          a.btn.btn-primary.btn-sm.fw-bold.mt-3(href="/") Volver al Inicio
