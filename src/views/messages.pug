extends layout

block content
  div.row
    div.col-md-8.col-lg-6.mx-auto
      h2.fw-bold.mb-4
        i.bi.bi-chat-left-dots.me-2.text-primary
        | #{title || 'Bandeja de Entrada'}

      if messages && messages.length > 0
        div.list-group.shadow-sm.border-0.mb-4
          each contact in messages
            div.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center.p-3
              div
                span.fw-bold.text-dark
                  i.bi.bi-person-circle.me-2.text-secondary
                  | Chat con @#{contact.username}
              a.btn.btn-primary.btn-sm.fw-bold(href=`/messages/${contact.id_usuario}`)
                | Abrir chat
      else
        div.text-center.py-5.bg-white.rounded.shadow-sm.p-4
          i.bi.bi-chat-square-text.fs-1.text-muted
          p.text-muted.mt-2.fw-bold No tienes conversaciones activas aún.
          p.text-muted.small.mb-4 Puedes iniciar una usando el botón "Me interesa" en las publicaciones de otros usuarios.
          a.btn.btn-primary.btn-sm.fw-bold(href="/") Explorar fotos
