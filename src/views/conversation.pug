extends layout

block content
  div.row
    div.col-md-8.col-lg-6.mx-auto
      div.card.shadow-sm.border-0
        div.card-header.bg-dark.text-white.d-flex.justify-content-between.align-items-center.py-3
          h5.mb-0.fw-bold
            i.bi.bi-chat-left-dots.me-2
            | @#{contactUser.username}
          a.btn.btn-outline-light.btn-sm.fw-bold(href="/messages")
            i.bi.bi-arrow-left.me-1
            | Volver
        
        div.card-body.bg-light.d-flex.flex-column.gap-2.overflow-auto(style="height: 380px;")
          if conversation && conversation.length > 0
            each msg in conversation
              - const isMe = msg.id_usuario_envia === currentUser
              div.d-flex.flex-column(class=isMe ? "align-self-end" : "align-self-start" style="max-width: 75%;")
                div.p-2.rounded-3.shadow-sm.small(class=isMe ? "bg-primary text-white" : "bg-white border text-dark")
                  p.mb-0.text-break= msg.texto_mensaje
                span.text-muted.mt-1(style="font-size: 0.7em;" class=isMe ? "align-self-end" : "align-self-start")
                  | #{new Date(msg.fecha_mensaje).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
          else
            div.my-auto.text-center.text-muted.fst-italic.small
              | No hay mensajes en este chat. ¡Comienza a escribir!
        
        div.card-footer.bg-white.p-3
          form(action=`/messages/${contactUser.id_usuario}/send` method="POST")
            div.input-group
              input.form-control(name="texto_mensaje" placeholder="Escribe un mensaje..." required autocomplete="off")
              button.btn.btn-success.fw-bold(type="submit")
                i.bi.bi-send.me-1
                | Enviar
