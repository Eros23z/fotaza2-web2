extends layout

block content
  .chat-layout(style="max-width: 600px; margin: 20px auto;")
    .chat-header(style="background-color: #2c3e50; color: white; padding: 15px; border-radius: 6px 6px 0 0; display: flex; justify-content: space-between; align-items: center;")
      h2(style="margin: 0; font-size: 1.2em;") @#{contactUser.username}
      a(href="/messages" style="color: #bdc3c7; text-decoration: none; font-size: 0.9em;") &larr; Volver
      
    .chat-messages(style="border: 1px solid #ddd; border-top: none; height: 350px; overflow-y: auto; padding: 20px; background-color: #fcfcfc; display: flex; flex-direction: column; gap: 12px;")
      if conversation && conversation.length > 0
        each msg in conversation
          - const isMe = msg.id_usuario_envia === currentUser
          div(style=`max-width: 75%; padding: 10px 14px; border-radius: 8px; font-size: 0.95em; line-height: 1.4em; word-wrap: break-word; ${isMe ? 'align-self: flex-end; background-color: #dcf8c6; border: 1px solid #c7eafc;' : 'align-self: flex-start; background-color: white; border: 1px solid #e0e0e0;'}`)
            p(style="margin: 0;") #{msg.texto_mensaje}
            span(style="display: block; font-size: 0.75em; color: #7f8c8d; text-align: right; margin-top: 4px;") #{new Date(msg.fecha_mensaje).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
      else
        p.empty-chat(style="text-align: center; color: #7f8c8d; font-style: italic; margin: auto;") No hay mensajes en este chat. ¡Comienza a escribir!
        
    .chat-footer(style="border: 1px solid #ddd; border-top: none; border-radius: 0 0 6px 6px; background-color: #f1f1f1; padding: 10px;")
      form(action=`/messages/${contactUser.id_usuario}/send` method="POST" style="display: flex; gap: 10px;")
        textarea(name="texto_mensaje" placeholder="Escribe un mensaje..." required style="flex-grow: 1; height: 40px; padding: 8px; border: 1px solid #ccc; border-radius: 4px; resize: none; font-family: inherit;")
        button(type="submit" style="background-color: #27ae60; color: white; border: none; padding: 0 20px; border-radius: 4px; font-weight: bold; cursor: pointer;") Enviar
