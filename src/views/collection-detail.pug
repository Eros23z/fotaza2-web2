extends layout

block content
  div.row
    div.col-lg-10.mx-auto
      div.d-flex.justify-content-between.align-items-center.mb-4.flex-wrap.gap-2
        h2.fw-bold.mb-0
          i.bi.bi-folder-symlink.me-2.text-primary
          | Colección: #{collection.nombre_collection}
        a.btn.btn-outline-secondary.btn-sm.fw-bold(href="/my-collections")
          i.bi.bi-arrow-left.me-1
          | Volver a Mis Colecciones

      if posts && posts.length > 0
        div.row.row-cols-1.row-cols-md-2.row-cols-lg-3.g-4
          each post in posts
            div.col
              div.card.h-100.shadow-sm.border-0
                if post.imagen_url
                  img.card-img-top(src=post.imagen_url alt=post.titulo style="height: 180px; object-fit: cover;")
                div.card-body.d-flex.flex-column.justify-content-between.p-3
                  div
                    h6.card-title.fw-bold.mb-1= post.titulo
                    p.card-text.text-muted.small.mb-3= post.descripcion ? (post.descripcion.length > 80 ? post.descripcion.substring(0, 80) + '...' : post.descripcion) : ''
                  
                  div.d-flex.justify-content-between.align-items-center.mt-3.pt-2.border-top
                    a.btn.btn-primary.btn-sm.fw-bold(href=`/posts-detail/${post.id_publicacion}`)
                      | Ver detalles
                    form(action=`/collections/${collection.id_collection}/delete/${post.id_publicacion}` method="POST" class="m-0")
                      button.btn.btn-outline-danger.btn-sm.fw-bold(type="submit")
                        | Quitar
      else
        div.text-center.py-5.bg-white.rounded.shadow-sm
          i.bi.bi-folder-x.fs-1.text-muted
          p.text-muted.mt-2.small Esta colección no tiene publicaciones guardadas aún.
