extends layout

block content
  div.row
    div.col-lg-10.mx-auto
      h2.fw-bold.mb-4
        i.bi.bi-folder2-open.me-2.text-primary
        | Mis Colecciones

      div.card.border-0.shadow-sm.mb-4
        div.card-body.p-4
          h5.card-title.fw-bold.mb-3 Crear Nueva Colección
          form(action="/collections" method="POST")
            div.row.g-2.align-items-center
              div.col-md-9
                input.form-control(type="text" name="nombre_collection" placeholder="Ej: Mis Favoritos, Paisajes, Inspiración..." required)
              div.col-md-3
                button.btn.btn-success.w-100.fw-bold(type="submit")
                  i.bi.bi-folder-plus.me-1
                  | Crear Carpeta

      h4.fw-bold.mb-3.mt-4 Mis Carpetas
      if collections && collections.length > 0
        div.row.row-cols-1.row-cols-md-2.row-cols-lg-3.g-4
          each col in collections
            div.col
              div.card.h-100.shadow-sm.border-0
                div.card-body.d-flex.flex-column.justify-content-between.p-3
                  div
                    h5.card-title.fw-bold.mb-1.text-dark= col.nombre_collection
                    p.text-muted.small.mb-3 Creada el #{new Date(col.fecha_creacion).toLocaleDateString()}
                  div.d-flex.justify-content-between.align-items-center.mt-3.pt-2.border-top
                    a.btn.btn-link.btn-sm.text-decoration-none.fw-bold.p-0(href=`/collections/${col.id_collection}`)
                      | Ver contenido &rarr;
                    form(action=`/collections/${col.id_collection}/delete` method="POST" onsubmit="return confirm('¿Estás seguro de que quieres eliminar esta colección? Se quitará la carpeta pero no se borrarán las publicaciones originales.')" class="m-0")
                      button.btn.btn-link.btn-sm.text-danger.text-decoration-none.fw-bold.p-0(type="submit")
                        | Eliminar
      else
        div.text-center.py-5.bg-white.rounded.shadow-sm
          i.bi.bi-folder-x.fs-1.text-muted
          p.text-muted.mt-2.small No tienes ninguna colección creada aún. ¡Crea una arriba para comenzar a guardar fotos!
