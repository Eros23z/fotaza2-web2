doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= title || "Fotaza 2"
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
    link(rel="stylesheet", href="/css/style.css")
  body.d-flex.flex-column.min-vh-100
    header
      nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.shadow-sm
        div.container
          a.navbar-brand.fw-bold(href="/")
            i.bi.bi-camera-fill.me-2
            | Fotaza 2
          button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation")
            span.navbar-toggler-icon
          
          div#navbarNav.collapse.navbar-collapse
            ul.navbar-nav.me-auto.mb-2.mb-lg-0
              li.nav-item
                a.nav-link.text-nowrap(href="/") Inicio
              if user
                li.nav-item
                  a.nav-link.text-nowrap(href="/create-post") Nueva Publicación
                li.nav-item
                  a.nav-link.text-nowrap(href="/messages") Mensajes
                li.nav-item
                  a.nav-link.text-nowrap(href="/my-collections") Colecciones
            
            form.d-flex.align-items-center.my-2.my-lg-0.me-lg-3(action="/search" method="GET" role="search" style="max-width: 300px; width: 100%;")
              div.position-relative.w-100
                i.bi.bi-search.position-absolute(style="left: 12px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.6); pointer-events: none;")
                input.form-control.form-control-sm.rounded-pill.bg-secondary.border-0.text-white(type="search" name="q" placeholder="Buscar..." aria-label="Buscar" value=searchTerm style="padding-left: 34px; height: 34px;")
            
            ul.navbar-nav.align-items-center
              if user
                li.nav-item.dropdown.me-3
                  a#notifDropdown.nav-link.position-relative(href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false")
                    i.bi.bi-bell-fill.fs-5
                    if notifications && notifications.filter(n => !n.leida).length > 0
                      span.position-absolute.top-0.start-100.translate-middle.badge.rounded-pill.bg-danger.small(style="font-size: 0.6em;")
                        | #{notifications.filter(n => !n.leida).length}
                  ul.dropdown-menu.dropdown-menu-end.shadow(aria-labelledby="notifDropdown" style="width: 290px; max-height: 350px; overflow-y: auto;")
                    if notifications && notifications.length > 0
                      each n in notifications
                        li
                          if n.tipo_evento === 'nuevo_seguidor'
                            span.dropdown-item-text.small.text-wrap @#{n.username} comenzó a seguirte.
                          else if n.tipo_evento === 'comentario'
                            a.dropdown-item.small.text-wrap(href=`/posts-detail/${n.id_publicacion}`) @#{n.username} comentó tu publicación.
                          else if n.tipo_evento === 'valoracion'
                            a.dropdown-item.small.text-wrap(href=`/posts-detail/${n.id_publicacion}`) @#{n.username} valoró tu imagen.
                          else if n.tipo_evento === 'me_interesa'
                            a.dropdown-item.small.text-wrap(href=`/posts-detail/${n.id_publicacion}`) @#{n.username} tiene interés en tu post.
                          else if n.tipo_evento === 'guardada'
                            a.dropdown-item.small.text-wrap(href=`/posts-detail/${n.id_publicacion}`) @#{n.username} guardó tu publicación.
                      li
                        hr.dropdown-divider
                      li
                        a.dropdown-item.text-center.small.text-primary.fw-bold(href="/notifications") Ver todas
                    else
                      li
                        span.dropdown-item-text.small.text-muted.text-center No tienes notificaciones
                
                li.nav-item.dropdown
                  a#userDropdown.nav-link.dropdown-toggle.fw-bold(href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false")
                    i.bi.bi-person-circle.me-1
                    | #{user.username}
                  ul.dropdown-menu.dropdown-menu-end.shadow(aria-labelledby="userDropdown")
                    li
                      a.dropdown-item(href=`/profile/${user.id}`)
                        i.bi.bi-person-fill.me-2
                        | Mi Perfil
                    li
                      a.dropdown-item(href="/profile/moderation/comments")
                        i.bi.bi-chat-left-dots-fill.me-2
                        | Moderar Comentarios
                    if user.rol === 'validador'
                      li
                        a.dropdown-item(href="/admin/reports")
                          i.bi.bi-shield-fill-exclamation.me-2
                          | Panel Moderación
                    li
                      hr.dropdown-divider
                    li
                      a.dropdown-item.text-danger(href="/logout")
                        i.bi.bi-box-arrow-right.me-2
                        | Salir
              else
                li.nav-item
                  a.btn.btn-outline-light.btn-sm.me-2.px-3.rounded-pill(href="/login") Entrar
                li.nav-item
                  a.btn.btn-primary.btn-sm.px-3.rounded-pill(href="/register") Registrarse
    
    main.container.my-5.flex-grow-1
      block content 

    footer.bg-dark.text-white-50.text-center.py-3.mt-auto.border-top.border-secondary
      div.container
        p.mb-0.small &copy; 2026 Fotaza 2 - Programación Web II
    
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")