extends layout

block content
  h1 #{title || 'Panel de Moderación'}

  .feed-container
    if reports && reports.length > 0
      each report in reports
        article.post-card(style="border-color: #f5c6cb;")
          .post-header(style="background-color: #fdf2f2; color: #721c24; display: flex; justify-content: space-between;")
            h2 Denuncia ##{report.id_denuncia} - Motivo: #{report.motivo}
            span.username Realizada por: @#{report.username_denunciante}
          
          .post-body
            p(style="font-weight: bold; margin-bottom: 5px;") Descripción detallada:
            p(style="background-color: #fafafa; padding: 10px; border-radius: 4px; border: 1px solid #eee; margin-top: 0;") #{report.descripcion}
            
            p(style="margin-bottom: 5px;")
              strong Objetivo de la denuncia: 
              if report.id_publicacion
                span Publicación ##{report.id_publicacion}
                div(style="margin-top: 10px;")
                  a.btn-detail(href=`/posts-detail/${report.id_publicacion}` target="_blank") Ver Publicación Denunciada
              else if report.id_comentario
                span Comentario ##{report.id_comentario}
                div(style="background-color: #fff9e6; border: 1px solid #ffeeba; padding: 8px; border-radius: 4px; margin-top: 8px; color: #856404;")
                  p(style="margin: 0; font-style: italic;") "#{report.texto_comentario}"
          
          .post-footer(style="display: flex; gap: 10px; justify-content: flex-end; padding: 15px; background-color: #fafafa;")
            form(action=`/admin/reports/${report.id_denuncia}/dismiss` method="POST" style="margin: 0;")
              button(type="submit" style="background-color: #7f8c8d; color: white; padding: 8px 16px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;") Desestimar
            form(action=`/admin/reports/${report.id_denuncia}/takedown` method="POST" style="margin: 0;")
              button(type="submit" style="background-color: #c0392b; color: white; padding: 8px 16px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;") Dar de baja
    else
      .no-posts(style="text-align: center; padding: 40px;")
        p(style="font-size: 1.2em; color: #7f8c8d;") No hay denuncias pendientes en este momento.
        a.btn-detail(href="/" style="display: inline-block; margin-top: 15px;") Volver al Inicio
