extends layout

block content
  div.row
    div.col-md-10.col-lg-8.mx-auto
      h2.fw-bold.mb-2
        i.bi.bi-shield-exclamation.me-2.text-danger
        | #{title || 'Panel de Moderación'}
      p.text-muted.small.mb-4 Panel de control para gestionar las denuncias de publicaciones y comentarios reportados en Fotaza 2.

      if reports && reports.length > 0
        each report in reports
          div.card.border-danger.mb-4.shadow-sm
            div.card-header.bg-danger-subtle.text-danger-emphasis.d-flex.justify-content-between.align-items-center.py-2
              span.fw-bold.small
                i.bi.bi-exclamation-triangle.me-1
                | Denuncia ##{report.id_denuncia} - Motivo: #{report.motivo}
              span.badge.bg-danger Realizada por: @#{report.username_denunciante}
            
            div.card-body
              p.small.fw-bold.mb-1 Descripción detallada:
              p.bg-light.p-2.rounded.border.small.text-dark.mb-3 #{report.descripcion}
              
              div.pt-2.border-top
                span.small.text-muted
                  strong Objetivo de la denuncia: 
                  if report.id_publicacion
                    span Publicación ##{report.id_publicacion}
                    div.mt-2
                      a.btn.btn-outline-primary.btn-sm.fw-bold(href=`/posts-detail/${report.id_publicacion}` target="_blank")
                        i.bi.bi-eye.me-1
                        | Ver Publicación Denunciada
                  else if report.id_comentario
                    span Comentario ##{report.id_comentario}
                    div.alert.alert-warning.p-2.mt-2.small.mb-0.fst-italic
                      | "#{report.texto_comentario}"

            div.card-footer.bg-light.d-flex.justify-content-end.gap-2.py-2
              form(action=`/admin/reports/${report.id_denuncia}/dismiss` method="POST" class="m-0")
                button.btn.btn-outline-secondary.btn-sm.fw-bold(type="submit")
                  i.bi.bi-check-lg.me-1
                  | Desestimar
              form(action=`/admin/reports/${report.id_denuncia}/takedown` method="POST" class="m-0")
                button.btn.btn-danger.btn-sm.fw-bold(type="submit")
                  i.bi.bi-trash.me-1
                  | Dar de baja
      else
        div.text-center.py-5.bg-white.rounded.shadow-sm.p-4
          i.bi.bi-shield-check.fs-1.text-muted
          p.text-muted.mt-2.small No hay denuncias pendientes en este momento.
          a.btn.btn-primary.btn-sm.fw-bold.mt-3(href="/") Volver al Inicio
